{
  "name": "rinklink-auth-service",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "npm run auth:migrate:yes && tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "npm run auth:migrate:yes && node dist/index.js",
    "auth:generate": "npx @better-auth/cli generate",
    "auth:migrate": "npx @better-auth/cli migrate",
    "auth:migrate:yes": "npx @better-auth/cli migrate -y"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "better-auth": "^1.5.6",
    "dotenv": "^17.3.1",
    "hono": "^4.12.9",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
