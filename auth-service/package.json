{
  "name": "rinklink-auth-service",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "tsx src/ensure-auth-schema.ts && npm run auth:migrate:yes && tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test src/**/*.test.ts",
    "start": "npm run build && npm run start:compiled",
    "start:compiled": "node dist/ensure-auth-schema.js && npm run auth:migrate:compiled:yes && node dist/index.js",
    "seed": "tsx src/seed.ts",
    "auth:generate": "npx @better-auth/cli generate --config ./src/auth.ts",
    "auth:migrate": "npx @better-auth/cli migrate --config ./src/auth.ts",
    "auth:migrate:yes": "npx @better-auth/cli migrate -y --config ./src/auth.ts",
    "auth:migrate:compiled": "npx @better-auth/cli migrate --config ./dist/auth.js",
    "auth:migrate:compiled:yes": "npx @better-auth/cli migrate -y --config ./dist/auth.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "better-auth": "^1.5.6",
    "dotenv": "^17.3.1",
    "hono": "^4.12.9",
    "nodemailer": "^7.0.13",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
